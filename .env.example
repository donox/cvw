DATABASE_URL=sqlite:///./data/cvw.db
APP_TITLE=CVW Membership Database
BASE_URL=http://localhost:8000
SECRET_KEY=change-this-in-production
ADMIN_INITIAL_PASSWORD=admin

# Mailgun API (preferred — bypasses ISP/cloud SMTP port blocks)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM=

# SMTP email fallback (leave SMTP_HOST empty to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_STARTTLS=true